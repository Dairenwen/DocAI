@import "./common/lib/weui.wxss";

page {
  min-height: 100%;
  background:
    radial-gradient(circle at top right, rgba(29, 87, 242, 0.18), transparent 32%),
    linear-gradient(180deg, #f8f1e5 0%, #fcfaf5 34%, #f3f6fb 100%);
  color: #162134;
  font-size: 16px;
  line-height: 1.5;
  font-family: "Avenir Next", "PingFang SC", "Noto Sans SC", sans-serif;
}

page > view {
  width: 100%;
}

view,
text,
button,
input,
textarea,
scroll-view {
  box-sizing: border-box;
}

button {
  margin: 0;
  font-size: 28rpx;
}

button::after {
  border: 0;
}

.doc-page {
  min-height: 100vh;
  padding: 28rpx 24rpx calc(28rpx + env(safe-area-inset-bottom));
}

.page-shell {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.hero-card {
  border-radius: 32rpx;
  padding: 32rpx 28rpx;
  background: linear-gradient(135deg, #10275f 0%, #1d57f2 60%, #73baff 100%);
  color: #fff8ef;
  box-shadow: 0 22rpx 48rpx rgba(19, 39, 96, 0.24);
}

.hero-kicker {
  font-size: 22rpx;
  letter-spacing: 2rpx;
  text-transform: uppercase;
  opacity: 0.78;
}

.hero-title {
  margin-top: 12rpx;
  font-size: 46rpx;
  line-height: 1.24;
  font-weight: 700;
}

.hero-desc {
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: rgba(255, 248, 239, 0.9);
}

.hero-actions {
  margin-top: 24rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.panel {
  border-radius: 28rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(223, 230, 241, 0.95);
  box-shadow: 0 14rpx 32rpx rgba(20, 33, 66, 0.08);
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 12rpx;
}

.section-title {
  font-size: 32rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #18233a;
}

.section-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #667086;
}

.metric-grid,
.action-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 16rpx 0;
}

.metric-card,
.action-card {
  width: calc(50% - 8rpx);
}

.metric-card {
  min-height: 164rpx;
  border-radius: 24rpx;
  padding: 22rpx;
  background: linear-gradient(180deg, #ffffff 0%, #eef3fb 100%);
  border: 1rpx solid #e3e8f3;
}

.metric-value {
  font-size: 48rpx;
  line-height: 1.1;
  font-weight: 700;
  color: #163b9b;
}

.metric-label {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #49556d;
}

.metric-note {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #70809f;
}

.action-card {
  padding: 24rpx 22rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
  border: 1rpx solid #e3eaf8;
}

.card-label {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 64rpx;
  height: 38rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: #edf2ff;
  color: #1c54ea;
  font-size: 20rpx;
  font-weight: 600;
}

.card-title {
  margin-top: 16rpx;
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #1c2942;
}

.card-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #657086;
}

.card-link {
  margin-top: 18rpx;
  font-size: 22rpx;
  color: #1d57f2;
  font-weight: 600;
}

.solid-btn,
.outline-btn,
.ghost-btn,
.warn-btn {
  height: 78rpx;
  line-height: 78rpx;
  padding: 0 30rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
}

.solid-btn {
  background: linear-gradient(135deg, #1d57f2 0%, #173dbb 100%);
  color: #ffffff;
}

.outline-btn {
  background: rgba(255, 255, 255, 0.14);
  color: #1d57f2;
  border: 1rpx solid rgba(29, 87, 242, 0.22);
}

.ghost-btn {
  background: #eff3fb;
  color: #40506e;
}

.warn-btn {
  background: #fff2ef;
  color: #d14b2d;
}

.inline-btn {
  height: 66rpx;
  line-height: 66rpx;
  padding: 0 24rpx;
  font-size: 24rpx;
}

.pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 44rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #eff3fb;
  color: #52627e;
  font-size: 22rpx;
}

.chip {
  display: inline-flex;
  align-items: center;
  min-height: 46rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  border: 1rpx solid rgba(255, 255, 255, 0.26);
  color: #fff8ef;
  font-size: 22rpx;
}

.empty-state {
  padding: 52rpx 24rpx;
  text-align: center;
}

.empty-title {
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #22304c;
}

.empty-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.65;
  color: #6a758c;
}

.toolbar-input,
.toolbar-picker {
  min-height: 82rpx;
  border-radius: 20rpx;
  border: 1rpx solid #dce3f0;
  background: #fbfcfe;
  color: #1d2940;
}

.toolbar-input {
  width: 100%;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.toolbar-picker {
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  font-size: 26rpx;
}

.info-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.info-row {
  display: flex;
  gap: 14rpx;
  align-items: flex-start;
}

.info-index {
  width: 42rpx;
  height: 42rpx;
  line-height: 42rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1d57f2 0%, #173dbb 100%);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  text-align: center;
  flex-shrink: 0;
}

.info-content {
  flex: 1;
}

.info-title {
  font-size: 28rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #20304d;
}

.info-desc {
  margin-top: 6rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #667086;
}

.text-muted {
  color: #6e778d;
}

.rise-in {
  animation: riseIn 0.45s ease both;
}

.document-swipe-btn {
  min-width: 108rpx !important;
}

.document-swipe-btn .weui-slideview__btn {
  height: 100%;
  padding: 0 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
}

.document-swipe-btn--favorite .weui-slideview__btn {
  background: linear-gradient(180deg, #ffc04d 0%, #ffae17 100%);
  color: #fffaf1;
}

.document-swipe-btn--delete .weui-slideview__btn {
  background: linear-gradient(180deg, #ff626a 0%, #ff454f 100%);
  color: #ffffff;
}

@keyframes riseIn {
  from {
    opacity: 0;
    transform: translateY(18rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.privacy-mask {
  position: fixed;
  inset: 0;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background: rgba(12, 20, 36, 0.54);
}

.privacy-dialog {
  width: 100%;
  max-width: 620rpx;
  padding: 32rpx 28rpx;
  border-radius: 30rpx;
  background: #ffffff;
  box-shadow: 0 24rpx 56rpx rgba(14, 24, 48, 0.24);
}

.privacy-dialog-title {
  font-size: 34rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #1b2a44;
}

.privacy-dialog-desc {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #637089;
}

.privacy-dialog-links {
  margin-top: 20rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
}

.privacy-dialog-link,
.link-btn {
  padding: 0;
  font-size: 24rpx;
  line-height: 1.6;
  color: #1d57f2;
  background: transparent;
}

.privacy-dialog-link::after,
.link-btn::after {
  border: 0;
}

.privacy-dialog-actions {
  margin-top: 28rpx;
  display: flex;
  gap: 16rpx;
}

.privacy-dialog-actions button {
  flex: 1;
}
