.result-actions {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.result-actions--stack {
  flex-direction: column;
}

.result-complete-panel {
  padding: 28rpx 24rpx;
}

.result-complete-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.result-complete-copy {
  flex: 1;
  min-width: 0;
}

.result-complete-title {
  font-size: 34rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #1b2840;
}

.result-complete-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #64748b;
}

.result-complete-duration {
  flex-shrink: 0;
  min-height: 52rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #e9f2ff;
  color: #1d57f2;
  font-size: 22rpx;
  line-height: 52rpx;
  font-weight: 700;
}

.result-file-card {
  margin-top: 20rpx;
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 24rpx 22rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f6faff 100%);
  border: 1rpx solid #e1e9f7;
}

.result-file-icon {
  width: 84rpx;
  height: 84rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: #eff3fa;
}

.result-file-icon--word {
  background: #e9f0ff;
  color: #2452d1;
}

.result-file-icon--excel {
  background: #e7f7ef;
  color: #16784a;
}

.result-file-icon--file {
  background: #eef2f8;
  color: #4c5f7a;
}

.result-file-icon-ext {
  max-width: 62rpx;
  font-size: 22rpx;
  line-height: 1.2;
  font-weight: 700;
  text-align: center;
  word-break: break-all;
}

.result-file-body {
  flex: 1;
  min-width: 0;
}

.result-file-label {
  font-size: 22rpx;
  line-height: 1.6;
  color: #718198;
}

.result-file-name {
  margin-top: 6rpx;
  font-size: 30rpx;
  line-height: 1.45;
  font-weight: 700;
  color: #1d2940;
  display: -webkit-box;
  overflow: hidden;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  word-break: break-word;
  word-wrap: break-word;
  overflow-wrap: anywhere;
}

.result-file-meta {
  margin-top: 12rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx 16rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #6b7b94;
}

.result-action-block {
  margin-top: 20rpx;
}

.result-action-row {
  display: flex;
  gap: 12rpx;
}

.result-action-btn {
  flex: 1;
  min-width: 0;
}

.result-action-wide {
  width: 100%;
  margin-top: 12rpx;
}

.result-detail-section {
  margin-top: 18rpx;
  border-top: 1rpx solid #e7eef7;
  padding-top: 18rpx;
}

.result-detail-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #4a5a72;
  font-weight: 600;
}

.result-detail-list {
  margin-top: 14rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.result-detail-item {
  padding: 18rpx;
  border-radius: 20rpx;
  background: #f8fbff;
  border: 1rpx solid #e0e8f5;
}

.result-detail-label {
  font-size: 22rpx;
  line-height: 1.6;
  color: #718198;
}

.result-detail-value {
  margin-top: 6rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #243247;
  white-space: pre-wrap;
  word-break: break-word;
}
