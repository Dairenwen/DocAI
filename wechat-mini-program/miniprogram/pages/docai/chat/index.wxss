page {
  background:
    radial-gradient(circle at top right, rgba(102, 120, 255, 0.12), transparent 28%),
    linear-gradient(180deg, #f7f8fe 0%, #f2f5fb 100%);
}

.chat-page {
  height: 100vh;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-sizing: border-box;
  color: #1f2940;
}

.chat-top {
  flex-shrink: 0;
  padding: 0 24rpx 10rpx;
  background: linear-gradient(180deg, rgba(247, 248, 254, 0.98) 0%, rgba(247, 248, 254, 0.74) 100%);
}

.chat-top__bar {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.chat-top__identity {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.chat-top__avatar {
  position: relative;
  width: 72rpx;
  height: 72rpx;
  flex-shrink: 0;
}

.chat-top__avatar-core {
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #5a73ff 0%, #7a63ff 100%);
  box-shadow: 0 14rpx 30rpx rgba(99, 102, 241, 0.2);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.chat-top__avatar-dot {
  position: absolute;
  right: 2rpx;
  bottom: 2rpx;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #33c16d;
  border: 4rpx solid rgba(247, 248, 254, 0.96);
}

.chat-top__text {
  flex: 1;
  min-width: 0;
}

.chat-top__title {
  font-size: 32rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #1d2740;
}

.chat-top__subtitle {
  margin-top: 4rpx;
  font-size: 20rpx;
  line-height: 1.4;
  color: #7b86a0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.chat-top__actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.top-action {
  width: 64rpx;
  height: 64rpx;
  flex-shrink: 0;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.84);
  border: 1rpx solid rgba(110, 127, 171, 0.14);
  box-shadow: 0 10rpx 24rpx rgba(70, 86, 128, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
}

.top-action__clock {
  position: relative;
  width: 24rpx;
  height: 24rpx;
  border: 2rpx solid #64708a;
  border-radius: 50%;
}

.top-action__clock-short,
.top-action__clock-long {
  position: absolute;
  left: 50%;
  top: 50%;
  background: #64708a;
  border-radius: 999rpx;
  transform-origin: left center;
}

.top-action__clock-short {
  width: 7rpx;
  height: 2rpx;
  transform: translateY(-50%) rotate(18deg);
}

.top-action__clock-long {
  width: 8rpx;
  height: 2rpx;
  transform: translateY(-50%) rotate(92deg);
}

.top-action__dots {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.top-action__dot {
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: #64708a;
}

.context-dock {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 16rpx 18rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.84);
  border: 1rpx solid rgba(110, 127, 171, 0.14);
  box-shadow: 0 12rpx 24rpx rgba(76, 93, 138, 0.05);
}

.context-dock__badge {
  min-width: 108rpx;
  height: 44rpx;
  line-height: 44rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(91, 114, 255, 0.11);
  color: #5a73ff;
  font-size: 21rpx;
  font-weight: 600;
  text-align: center;
  flex-shrink: 0;
}

.context-dock__body {
  flex: 1;
  min-width: 0;
}

.context-dock__title {
  font-size: 27rpx;
  line-height: 1.35;
  font-weight: 600;
  color: #1e2841;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.context-dock__desc {
  margin-top: 6rpx;
  font-size: 21rpx;
  line-height: 1.5;
  color: #7b86a0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.context-dock__actions {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.context-dock__action {
  font-size: 22rpx;
  line-height: 1;
  color: #5a73ff;
}

.context-dock__action--muted {
  color: #8b95ad;
}

.context-dock__separator {
  width: 1rpx;
  height: 24rpx;
  background: rgba(128, 140, 170, 0.28);
}

.state-chip {
  margin-top: 12rpx;
  padding: 14rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(110, 127, 171, 0.14);
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.state-chip--doc-processing {
  background: rgba(244, 248, 255, 0.94);
  border-color: rgba(135, 162, 255, 0.26);
}

.state-chip--network-error {
  background: rgba(255, 247, 245, 0.96);
  border-color: rgba(255, 153, 137, 0.22);
}

.state-chip--service-busy {
  background: rgba(255, 249, 240, 0.96);
  border-color: rgba(255, 187, 103, 0.22);
}

.state-chip__text {
  flex: 1;
  min-width: 0;
}

.state-chip__title {
  font-size: 22rpx;
  line-height: 1.35;
  font-weight: 600;
  color: #24304a;
}

.state-chip__desc {
  margin-top: 4rpx;
  font-size: 20rpx;
  line-height: 1.45;
  color: #7a86a0;
}

.state-chip__action {
  flex-shrink: 0;
  min-width: 70rpx;
  height: 42rpx;
  line-height: 42rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: rgba(91, 114, 255, 0.1);
  color: #5a73ff;
  font-size: 20rpx;
  text-align: center;
}

.chat-body {
  flex: 1;
  min-height: 0;
  padding: 14rpx 24rpx calc(156rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.chat-scroll {
  height: 100%;
  min-height: 0;
}

.welcome-stage {
  padding-top: 10rpx;
}

.welcome-card {
  max-width: 92%;
  padding: 24rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(110, 127, 171, 0.1);
  box-shadow: 0 14rpx 28rpx rgba(73, 94, 145, 0.05);
}

.welcome-card__title {
  font-size: 30rpx;
  line-height: 1.4;
  font-weight: 700;
  color: #202c46;
}

.welcome-card__desc {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.72;
  color: #5f6f92;
}

.prompt-grid {
  margin: 22rpx 0 0 72rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.prompt-card {
  width: calc((100% - 14rpx) / 2);
  min-height: 118rpx;
  padding: 18rpx 18rpx 20rpx;
  box-sizing: border-box;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(110, 127, 171, 0.1);
  box-shadow: 0 10rpx 20rpx rgba(70, 88, 132, 0.05);
}

.prompt-card__title {
  font-size: 25rpx;
  line-height: 1.4;
  font-weight: 600;
  color: #273453;
}

.prompt-card__desc {
  margin-top: 8rpx;
  font-size: 21rpx;
  line-height: 1.55;
  color: #7b86a0;
}

.message-list {
  padding-top: 6rpx;
}

.message {
  display: flex;
  margin-bottom: 30rpx;
}

.message--ai {
  align-items: flex-start;
  gap: 6rpx;
}

.message--user {
  justify-content: flex-end;
}

.message__avatar {
  width: 46rpx;
  height: 46rpx;
  flex-shrink: 0;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #5a73ff 0%, #7a63ff 100%);
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 20rpx rgba(99, 102, 241, 0.13);
}

.message__content {
  flex: 1;
  min-width: 0;
  max-width: calc(100% - 72rpx);
}

.message--ai .message__content {
  max-width: calc(100% - 50rpx);
}

.message__content--user {
  max-width: 72%;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.ai-text {
  width: 100%;
  max-width: 100%;
  margin-left: -4rpx;
  padding-top: 0;
  padding-right: 0;
}

.ai-text__paragraph {
  font-size: 27rpx;
  line-height: 1.58;
  color: #22304c;
  text-align: left;
  text-indent: 0.25em;
  white-space: pre-wrap;
  word-break: break-word;
}

.ai-text__paragraph + .ai-text__paragraph {
  margin-top: 10rpx;
}

.ai-card {
  max-width: 90%;
  padding: 22rpx 22rpx 18rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(110, 127, 171, 0.1);
  box-shadow: 0 14rpx 26rpx rgba(73, 94, 145, 0.05);
}

.ai-card__title {
  font-size: 28rpx;
  line-height: 1.4;
  font-weight: 700;
  color: #22304c;
}

.ai-card__row {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(110, 127, 171, 0.1);
}

.ai-card__row:last-of-type {
  border-bottom: none;
}

.ai-card__label {
  font-size: 24rpx;
  line-height: 1.5;
  color: #7a86a0;
}

.ai-card__value {
  flex: 1;
  font-size: 25rpx;
  line-height: 1.5;
  color: #22304c;
  text-align: right;
  word-break: break-word;
}

.ai-card__tip {
  margin-top: 14rpx;
  font-size: 23rpx;
  line-height: 1.65;
  color: #7b86a0;
  white-space: pre-wrap;
}

.user-bubble {
  max-width: 100%;
  padding: 20rpx 22rpx;
  border-radius: 24rpx 24rpx 10rpx 24rpx;
  background: linear-gradient(135deg, #607cff 0%, #775fff 100%);
  color: #ffffff;
  font-size: 27rpx;
  line-height: 1.64;
  box-shadow: 0 14rpx 28rpx rgba(103, 96, 255, 0.18);
  white-space: pre-wrap;
  word-break: break-word;
}

.message__time {
  margin-top: 10rpx;
  font-size: 20rpx;
  color: #a0abc3;
}

.message__time--user {
  margin-right: 8rpx;
  text-align: right;
}

.thinking-bubble {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  min-width: 120rpx;
  padding: 18rpx 22rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(110, 127, 171, 0.1);
  box-shadow: 0 12rpx 24rpx rgba(73, 94, 145, 0.05);
}

.thinking-bubble__dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #90a0c2;
  animation: thinkingPulse 1.1s ease-in-out infinite;
}

.thinking-bubble__dot:nth-child(2) {
  animation-delay: 0.16s;
}

.thinking-bubble__dot:nth-child(3) {
  animation-delay: 0.32s;
}

.composer-shell {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 24;
  padding: 12rpx 24rpx calc(env(safe-area-inset-bottom) + 12rpx);
  background: linear-gradient(180deg, rgba(242, 245, 251, 0) 0%, rgba(242, 245, 251, 0.9) 38%, rgba(242, 245, 251, 0.98) 100%);
  box-sizing: border-box;
}

.composer-bar {
  min-height: 98rpx;
  padding: 14rpx 16rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(110, 127, 171, 0.1);
  box-shadow: 0 18rpx 36rpx rgba(72, 92, 145, 0.1);
  display: flex;
  align-items: flex-end;
  gap: 14rpx;
}

.composer-bar__plus {
  position: relative;
  width: 60rpx;
  height: 60rpx;
  flex-shrink: 0;
  border-radius: 20rpx;
  background: #f3f6fb;
}

.composer-bar__plus-line {
  position: absolute;
  left: 50%;
  top: 50%;
  background: #687997;
  border-radius: 999rpx;
  transform: translate(-50%, -50%);
}

.composer-bar__plus-line--vertical {
  width: 3rpx;
  height: 20rpx;
}

.composer-bar__plus-line--horizontal {
  width: 20rpx;
  height: 3rpx;
}

.composer-bar__input {
  flex: 1;
  width: auto;
  min-height: 44px;
  max-height: 108px;
  padding: 8rpx 0 10rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #223252;
  background: transparent;
}

.composer-bar__input[disabled] {
  color: #9aa7c1;
}

.composer-bar__placeholder {
  color: #aeb8ca;
}

.composer-bar__send {
  width: 60rpx;
  height: 60rpx;
  flex-shrink: 0;
  border-radius: 20rpx;
  background: #dbe3ef;
  display: flex;
  align-items: center;
  justify-content: center;
}

.composer-bar__send--active {
  background: linear-gradient(135deg, #5f7cff 0%, #765dff 100%);
  box-shadow: 0 12rpx 24rpx rgba(103, 96, 255, 0.22);
}

.composer-bar__send-icon {
  position: relative;
  width: 24rpx;
  height: 24rpx;
}

.composer-bar__send-wing {
  position: absolute;
  left: 7rpx;
  top: 4rpx;
  width: 0;
  height: 0;
  border-top: 8rpx solid transparent;
  border-bottom: 8rpx solid transparent;
  border-left: 14rpx solid #ffffff;
  transform: rotate(-14deg);
}

.composer-bar__send-tail {
  position: absolute;
  left: 5rpx;
  top: 11rpx;
  width: 11rpx;
  height: 2rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  transform: rotate(26deg);
}

.overlay {
  position: fixed;
  inset: 0;
  z-index: 60;
  background: rgba(18, 24, 38, 0.22);
  display: flex;
}

.history-drawer {
  margin-left: auto;
  width: 78%;
  height: 100vh;
  padding: calc(env(safe-area-inset-top) + 24rpx) 22rpx calc(24rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  display: flex;
  flex-direction: column;
  box-shadow: -16rpx 0 40rpx rgba(24, 35, 64, 0.14);
}

.drawer-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.drawer-title {
  font-size: 32rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #1f2940;
}

.drawer-primary {
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: rgba(91, 114, 255, 0.1);
  color: #5a73ff;
  font-size: 22rpx;
}

.drawer-scroll {
  flex: 1;
  min-height: 0;
  margin-top: 22rpx;
}

.drawer-empty {
  padding: 64rpx 12rpx;
  text-align: center;
  font-size: 24rpx;
  color: #8491aa;
}

.history-section + .history-section {
  margin-top: 22rpx;
}

.history-section__title {
  font-size: 22rpx;
  color: #8a96ac;
}

.history-item {
  margin-top: 12rpx;
  padding: 18rpx 16rpx;
  border-radius: 22rpx;
  background: #f7f9fd;
  border: 1rpx solid rgba(110, 127, 171, 0.08);
}

.history-item--active {
  background: rgba(91, 114, 255, 0.08);
  border-color: rgba(91, 114, 255, 0.12);
}

.history-item__title {
  font-size: 26rpx;
  line-height: 1.45;
  font-weight: 600;
  color: #1f2940;
  word-break: break-word;
}

.history-item__time {
  margin-top: 8rpx;
  font-size: 21rpx;
  color: #8792a8;
}

.sheet {
  margin-top: auto;
  width: 100%;
  padding: 22rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  border-radius: 32rpx 32rpx 0 0;
  background: #ffffff;
  box-shadow: 0 -14rpx 38rpx rgba(24, 35, 64, 0.14);
}

.sheet--document {
  max-height: 74vh;
  display: flex;
  flex-direction: column;
}

.sheet__title {
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #1f2940;
}

.sheet__list {
  margin-top: 14rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.sheet-item {
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: #f8faff;
  border: 1rpx solid rgba(110, 127, 171, 0.08);
}

.sheet-item--disabled {
  opacity: 0.45;
}

.sheet-item--danger {
  background: #fff8f6;
  border-color: rgba(255, 138, 117, 0.12);
}

.sheet-item__title {
  font-size: 26rpx;
  line-height: 1.4;
  font-weight: 600;
  color: #1f2940;
}

.sheet-item__desc {
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.55;
  color: #8090aa;
}

.sheet__empty {
  padding: 56rpx 12rpx;
  text-align: center;
  font-size: 24rpx;
  color: #8390a8;
}

.sheet__empty-text {
  font-size: 24rpx;
  line-height: 1.6;
}

.sheet__retry {
  display: inline-block;
  margin-top: 16rpx;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: rgba(91, 114, 255, 0.1);
  color: #5a73ff;
  font-size: 22rpx;
}

.document-scroll {
  flex: 1;
  min-height: 0;
  margin-top: 14rpx;
}

.document-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  padding: 18rpx 8rpx;
  border-bottom: 1rpx solid rgba(110, 127, 171, 0.08);
}

.document-item--disabled {
  opacity: 0.72;
}

.document-item--active {
  margin-bottom: 8rpx;
  padding: 18rpx 16rpx;
  border-radius: 22rpx;
  border: 1rpx solid rgba(91, 114, 255, 0.12);
  background: rgba(91, 114, 255, 0.06);
}

.document-item__main {
  flex: 1;
  min-width: 0;
}

.document-item__title {
  font-size: 26rpx;
  line-height: 1.45;
  font-weight: 600;
  color: #1f2940;
  word-break: break-word;
}

.document-item__meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8792a8;
}

.document-item__stage {
  display: inline-flex;
  align-items: center;
  margin-top: 10rpx;
  padding: 0 14rpx;
  min-height: 40rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  line-height: 40rpx;
  background: rgba(128, 140, 170, 0.1);
  color: #6f7c97;
}

.document-item__stage--success {
  background: rgba(51, 193, 109, 0.12);
  color: #1f9a53;
}

.document-item__stage--warning {
  background: rgba(255, 187, 103, 0.14);
  color: #c67a17;
}

.document-item__stage--danger {
  background: rgba(255, 138, 117, 0.12);
  color: #d3563a;
}

.document-item__desc {
  margin-top: 8rpx;
  font-size: 21rpx;
  line-height: 1.5;
  color: #8a96ac;
}

.document-item__tag {
  flex-shrink: 0;
  min-height: 42rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: rgba(91, 114, 255, 0.1);
  color: #5a73ff;
  font-size: 20rpx;
  line-height: 42rpx;
}

@keyframes thinkingPulse {
  0%,
  80%,
  100% {
    transform: scale(0.7);
    opacity: 0.45;
  }

  40% {
    transform: scale(1);
    opacity: 1;
  }
}
