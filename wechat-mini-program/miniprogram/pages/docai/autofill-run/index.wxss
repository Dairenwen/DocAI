.run-metrics {
  margin-top: 18rpx;
}

.run-toolbar {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.run-toolbar--stack {
  flex-direction: column;
}

.run-doc-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.run-doc-card {
  padding: 22rpx;
  border-radius: 24rpx;
  background: #f9fbff;
  border: 1rpx solid #dde5f4;
}

.run-doc-card--warning {
  background: #fffaf0;
  border-color: #f1deaf;
}

.run-doc-card--info {
  background: #f3f7ff;
  border-color: #cddfff;
}

.run-doc-card--success {
  background: #f4fff8;
  border-color: #cde9d9;
}

.run-doc-card--danger {
  background: #fff4f3;
  border-color: #f0d1cc;
}

.run-doc-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.run-doc-main {
  flex: 1;
  min-width: 0;
}

.run-doc-title {
  font-size: 28rpx;
  line-height: 1.5;
  color: #19263f;
  font-weight: 700;
  word-break: break-word;
}

.run-doc-meta {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.6;
  color: #66748b;
}

.run-doc-stage {
  min-height: 46rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #eef3fc;
  color: #5c6b81;
  font-size: 22rpx;
  line-height: 46rpx;
  white-space: nowrap;
}

.run-doc-stage--warning {
  background: #fff1cc;
  color: #996700;
}

.run-doc-stage--info {
  background: #e7f0ff;
  color: #315fb0;
}

.run-doc-stage--success {
  background: #ddf8e8;
  color: #23734b;
}

.run-doc-stage--danger {
  background: #ffe2de;
  color: #c04d3a;
}

.run-doc-desc {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #5e6f86;
}

.run-doc-remove {
  margin-top: 18rpx;
  width: 100%;
}

.run-template-card,
.run-textarea-card {
  margin-top: 18rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f6faff 100%);
  border: 1rpx solid #e1e9f7;
}

.run-template-label {
  font-size: 22rpx;
  color: #66748b;
}

.run-template-value {
  margin-top: 10rpx;
  font-size: 30rpx;
  line-height: 1.6;
  color: #173256;
  font-weight: 700;
  word-break: break-all;
}

.run-textarea {
  width: 100%;
  min-height: 220rpx;
  margin-top: 14rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  background: #f7faff;
  color: #22324d;
  font-size: 26rpx;
  line-height: 1.7;
}

.run-textarea-count {
  margin-top: 10rpx;
  text-align: right;
  font-size: 22rpx;
  color: #75839b;
}

.run-progress-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.run-progress-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-height: 54rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #f2f6fd;
}

.run-progress-item--active {
  background: #e8f0ff;
}

.run-progress-item--done {
  background: #e3f8ec;
}

.run-progress-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 999rpx;
  background: #92a0b8;
}

.run-progress-item--active .run-progress-dot {
  background: #1d57f2;
}

.run-progress-item--done .run-progress-dot {
  background: #26a269;
}

.run-progress-text {
  font-size: 24rpx;
  color: #425168;
}

.run-progress-note {
  margin-top: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: #f4f8ff;
  color: #38537f;
  font-size: 24rpx;
  line-height: 1.7;
}

.run-error-note {
  margin-top: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: #fff2ef;
  color: #c5553f;
  font-size: 24rpx;
  line-height: 1.7;
}

.run-submit-btn {
  width: 100%;
  margin-top: 18rpx;
}
