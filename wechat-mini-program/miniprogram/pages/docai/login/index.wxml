<view class="doc-page auth-page">
  <view class="page-shell">
    <view class="auth-copy rise-in">
      <view class="hero-kicker">DocAI Workspace</view>
      <view class="auth-title">把资料整理、字段抽取和智能问答放进同一条移动工作流</view>
      <view class="auth-desc">
        小程序已接入 DocAI 服务，登录、文档上传、智能问答和模板填表都可以在同一处完成。
      </view>
    </view>

    <view class="auth-feature-row rise-in">
      <view class="auth-feature">
        <view class="feature-badge">01</view>
        <view class="feature-title">文档集中管理</view>
        <view class="feature-desc">上传后统一筛选、预览、进入问答。</view>
      </view>
      <view class="auth-feature">
        <view class="feature-badge">02</view>
        <view class="feature-title">填表链路前置</view>
        <view class="feature-desc">模板选择和来源文档状态在同一屏展示。</view>
      </view>
      <view class="auth-feature">
        <view class="feature-badge">03</view>
        <view class="feature-title">进度清晰可见</view>
        <view class="feature-desc">关键状态集中展示，便于快速确认资料处理进展。</view>
      </view>
      <view class="auth-feature">
        <view class="feature-badge">04</view>
        <view class="feature-title">统一流程处理</view>
        <view class="feature-desc">账号、文档、问答和填表结果在同一应用内衔接。</view>
      </view>
    </view>

    <view class="auth-card rise-in">
      <view class="auth-tabs">
        <view
          class="auth-tab {{isLogin ? 'auth-tab--active' : ''}}"
          data-login="true"
          bindtap="switchMode"
        >
          登录
        </view>
        <view
          class="auth-tab {{!isLogin ? 'auth-tab--active' : ''}}"
          data-login="false"
          bindtap="switchMode"
        >
          注册
        </view>
      </view>

      <view class="auth-mode-title">{{modeTitle}}</view>
      <view class="auth-mode-desc">{{modeDesc}}</view>

      <view class="field-block">
        <view class="field-label">用户名</view>
        <input
          class="auth-input"
          placeholder-class="auth-placeholder"
          placeholder="请输入用于登录的用户名"
          value="{{username}}"
          bindinput="onUsernameInput"
        />
      </view>

      <view class="field-block">
        <view class="field-label">密码</view>
        <input
          class="auth-input"
          password
          placeholder-class="auth-placeholder"
          placeholder="请输入密码"
          value="{{password}}"
          bindinput="onPasswordInput"
        />
      </view>

      <view class="field-block" wx:if="{{!isLogin}}">
        <view class="field-label">确认密码</view>
        <input
          class="auth-input"
          password
          placeholder-class="auth-placeholder"
          placeholder="请再次输入密码"
          value="{{confirmPassword}}"
          bindinput="onConfirmPasswordInput"
        />
      </view>

      <view class="policy-row" bindtap="togglePolicyAgreement">
        <view class="policy-check {{agreedToPolicies ? 'policy-check--active' : ''}}">
          <view wx:if="{{agreedToPolicies}}" class="policy-check-dot"></view>
        </view>
        <view class="policy-copy">
          我已阅读并同意
          <text class="policy-link" catchtap="openUserAgreement">《用户协议》</text>
          与
          <text class="policy-link" catchtap="openPrivacyPolicy">《隐私政策》</text>
        </view>
      </view>

      <button
        class="solid-btn auth-submit {{!agreedToPolicies ? 'auth-submit--disabled' : ''}}"
        loading="{{loading}}"
        bindtap="submit"
      >
        {{submitText}}
      </button>

      <view class="auth-tip">{{modeTip}}</view>
    </view>
  </view>

  <view wx:if="{{privacyDialog.visible}}" class="privacy-mask">
    <view class="privacy-dialog">
      <view class="privacy-dialog-title">隐私授权提示</view>
      <view class="privacy-dialog-desc">
        为了{{privacyDialog.sceneText}}，请先阅读并同意《用户协议》《隐私政策》。
      </view>
      <view class="privacy-dialog-links">
        <button class="privacy-dialog-link" bindtap="openUserAgreement">查看用户协议</button>
        <button class="privacy-dialog-link" bindtap="openPrivacyPolicy">查看隐私政策</button>
      </view>
      <view class="privacy-dialog-actions">
        <button class="ghost-btn inline-btn" bindtap="handlePrivacyDisagree">暂不同意</button>
        <button
          id="{{privacyDialog.agreeButtonId}}"
          class="solid-btn inline-btn"
          open-type="agreePrivacyAuthorization"
          bindagreeprivacyauthorization="handlePrivacyAgree"
        >
          同意并继续
        </button>
      </view>
    </view>
  </view>
</view>
