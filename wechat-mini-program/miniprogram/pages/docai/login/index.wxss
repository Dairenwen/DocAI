.auth-page {
  padding-top: 44rpx;
}

.auth-copy {
  padding: 8rpx 8rpx 0;
}

.auth-title {
  margin-top: 16rpx;
  font-size: 56rpx;
  line-height: 1.16;
  font-weight: 700;
  color: #18233a;
}

.auth-desc {
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 1.75;
  color: #5f687a;
}

.auth-feature-row {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 16rpx 0;
}

.auth-feature {
  width: calc(50% - 8rpx);
  padding: 22rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.84);
  border: 1rpx solid #e6ebf4;
  box-shadow: 0 12rpx 28rpx rgba(21, 33, 66, 0.05);
}

.feature-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 62rpx;
  height: 40rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: #ebf1ff;
  color: #1d57f2;
  font-size: 20rpx;
  font-weight: 700;
}

.feature-title {
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 1.4;
  font-weight: 700;
  color: #1e2a42;
}

.feature-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #6a7387;
}

.auth-card {
  padding: 28rpx 24rpx 24rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid #e4eaf6;
  box-shadow: 0 18rpx 36rpx rgba(20, 33, 66, 0.08);
}

.auth-tabs {
  display: flex;
  padding: 6rpx;
  border-radius: 999rpx;
  background: #eef2f8;
}

.auth-tab {
  flex: 1;
  height: 70rpx;
  line-height: 70rpx;
  text-align: center;
  border-radius: 999rpx;
  font-size: 28rpx;
  color: #667086;
}

.auth-tab--active {
  background: #ffffff;
  color: #1d57f2;
  font-weight: 700;
  box-shadow: 0 8rpx 18rpx rgba(29, 87, 242, 0.14);
}

.auth-mode-title {
  margin-top: 26rpx;
  font-size: 36rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #17233a;
}

.auth-mode-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #697287;
}

.field-block {
  margin-top: 22rpx;
}

.field-label {
  margin-bottom: 10rpx;
  font-size: 24rpx;
  color: #667086;
}

.auth-input {
  height: 88rpx;
  padding: 0 24rpx;
  border-radius: 18rpx;
  border: 1rpx solid #dde4f0;
  background: #f9fbff;
  font-size: 28rpx;
  color: #18233a;
  caret-color: #1d57f2;
}

.auth-placeholder {
  color: #9aa5b9;
}

.auth-submit {
  width: 100%;
  margin-top: 30rpx;
}

.auth-submit--disabled {
  opacity: 0.56;
}

.auth-tip {
  margin-top: 16rpx;
  text-align: center;
  font-size: 24rpx;
  line-height: 1.6;
  color: #6b7487;
}

.policy-row {
  margin-top: 24rpx;
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.policy-check {
  width: 34rpx;
  height: 34rpx;
  margin-top: 4rpx;
  border-radius: 50%;
  border: 2rpx solid #c6d0e1;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.policy-check--active {
  border-color: #1d57f2;
  background: #1d57f2;
}

.policy-check-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #ffffff;
}

.policy-copy {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.7;
  color: #5d687f;
}

.policy-link {
  color: #1d57f2;
  font-weight: 600;
}

.dev-entry {
  margin-top: 20rpx;
  text-align: center;
  font-size: 20rpx;
  color: rgba(107, 116, 135, 0.42);
  letter-spacing: 1rpx;
}
