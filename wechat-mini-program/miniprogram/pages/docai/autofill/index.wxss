}

.source-picker-file--word {
  background: #e9f0ff;
  color: #2452d1;
}

.source-picker-file--excel {
  background: #e7f7ef;
  color: #16784a;
}

.source-picker-file--markdown,
.source-picker-file--text {
  background: #eef2f8;
  color: #4c5f7a;
}

.source-picker-file-ext {
  max-width: 58rpx;
  font-size: 20rpx;
  line-height: 1.2;
  font-weight: 700;
  text-align: center;
  word-break: break-all;
}

.source-picker-body {
  flex: 1;
  min-width: 0;
}

.source-picker-name {
  display: -webkit-box;
  overflow: hidden;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  font-size: 28rpx;
  line-height: 1.45;
  font-weight: 700;
  color: #1d2940;
  word-break: break-all;
  word-wrap: break-word;
  overflow-wrap: anywhere;
}

.source-picker-meta {
  margin-top: 8rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx 12rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #6c7b94;
}

.source-picker-status {
  display: inline-flex;
  align-items: center;
  min-height: 42rpx;
  margin-top: 10rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: #eef3fc;
  color: #5c6b81;
  font-size: 21rpx;
  line-height: 42rpx;
}

.source-picker-status--warning {
  background: #fff1cc;
  color: #996700;
}

.source-picker-status--info {
  background: #e7f0ff;
  color: #315fb0;
}

.source-picker-status--success {
  background: #ddf8e8;
  color: #23734b;
}

.source-picker-status--danger {
  background: #ffe2de;
  color: #c04d3a;
}

.source-picker-check {
  width: 44rpx;
  height: 44rpx;
  margin-top: 6rpx;
  border-radius: 999rpx;
  border: 2rpx solid #c4cfdf;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-sizing: border-box;
}

.source-picker-check--selected {
  border-color: #1da35a;
  background: #1da35a;
  color: #ffffff;
  box-shadow: 0 8rpx 18rpx rgba(29, 163, 90, 0.22);
}

.source-picker-check--disabled {
  border-color: #d6dde9;
  background: #f4f7fb;
}

.source-picker-check-mark {
  font-size: 24rpx;
  line-height: 1;
  color: #ffffff;
}

.source-picker-empty {
  padding: 108rpx 28rpx 140rpx;
  text-align: center;
}

.source-picker-empty-title {
  font-size: 28rpx;
  line-height: 1.5;
  font-weight: 700;
  color: #1d2940;
}

.source-picker-empty-desc {
  margin-top: 10rpx;
  font-size: 23rpx;
  line-height: 1.7;
  color: #6b7b94;
}

.source-picker-footer {
  display: flex;
  gap: 12rpx;
  padding: 18rpx 20rpx 0;
  background: #ffffff;
}

.source-picker-footer-btn {
  flex: 1;
}

.template-sheet-mask {
  position: fixed;
  inset: 0;
  background: rgba(10, 18, 32, 0);
  transition: background 260ms ease;
  z-index: 92;
}

.template-sheet-mask--visible {
  background: rgba(10, 18, 32, 0.38);
}

.template-action-sheet,
.template-picker-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 32rpx 32rpx 0 0;
  background: #ffffff;
  box-shadow: 0 -18rpx 56rpx rgba(15, 23, 42, 0.18);
  transform: translateY(100%);
  opacity: 0;
  transition: transform 260ms cubic-bezier(0.22, 1, 0.36, 1), opacity 260ms ease;
  z-index: 93;
}

.template-action-sheet--visible,
.template-picker-panel--visible {
  transform: translateY(0);
  opacity: 1;
}

.template-action-sheet {
  padding: 10rpx 20rpx calc(env(safe-area-inset-bottom) + 20rpx);
}

.template-picker-panel {
  height: 70vh;
  max-height: 1080rpx;
  padding: 10rpx 0 calc(env(safe-area-inset-bottom) + 20rpx);
  display: flex;
  flex-direction: column;
}

.template-sheet-header {
  padding: 0 8rpx 20rpx;
}

.template-action-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.template-action-btn {
  width: 100%;
  min-height: 92rpx;
  border-radius: 24rpx;
  background: #f6f8fc;
  color: #1d2940;
  font-size: 28rpx;
  line-height: 1.5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.template-action-btn::after {
  border: 0;
}

.template-action-btn--cancel {
  background: #fff4f2;
  color: #c5553f;
}

.template-picker-radio {
  width: 42rpx;
  height: 42rpx;
  margin-top: 6rpx;
  border-radius: 999rpx;
  border: 2rpx solid #c4cfdf;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  flex-shrink: 0;
}

.template-picker-radio--selected {
  border-color: #1f58ef;
}

.template-picker-radio-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 999rpx;
  background: transparent;
}

.template-picker-radio--selected .template-picker-radio-dot {
  background: #1f58ef;
}

.selected-source-card--lite {
  align-items: center;
}

.selected-source-side--lite {
  min-width: auto;
  justify-content: center;
}

.source-picker-meta--stacked {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx 12rpx;
}

.privacy-mask {
  position: fixed;
  inset: 0;
  z-index: 2000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  background: rgba(15, 23, 42, 0.45);
  box-sizing: border-box;
}

.privacy-dialog {
  width: 100%;
  max-width: 640rpx;
  padding: 40rpx 36rpx 32rpx;
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 24rpx 80rpx rgba(15, 23, 42, 0.22);
  box-sizing: border-box;
}

.privacy-dialog-title {
  color: #162033;
  font-size: 34rpx;
  font-weight: 700;
}

.privacy-dialog-desc {
  margin-top: 18rpx;
  color: #5d6a7f;
  font-size: 27rpx;
  line-height: 1.7;
}

.privacy-dialog-links {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.privacy-dialog-link {
  margin: 0;
  padding: 0;
  background: transparent;
  color: #1f58ef;
  font-size: 26rpx;
  line-height: 1.5;
}

.privacy-dialog-link::after {
  border: 0;
}

.privacy-dialog-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 32rpx;
}

.privacy-dialog-actions .inline-btn {
  flex: 1;
}
