.contact-page {
  padding-top: 20rpx;
}

.contact-card-list,
.contact-list {
  margin-top: 16rpx;
}

.contact-card-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.contact-card {
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f6f9ff 100%);
  border: 1rpx solid #e3eaf8;
}

.contact-card-label {
  font-size: 22rpx;
  color: #72809a;
}

.contact-card-value {
  margin-top: 8rpx;
  font-size: 28rpx;
  line-height: 1.45;
  font-weight: 700;
  color: #1b2a44;
  word-break: break-word;
}

.contact-card-desc,
.contact-item {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #61708a;
}

.contact-item {
  margin-top: 12rpx;
}

.contact-item::before {
  content: '• ';
}

.contact-actions {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.contact-btn {
  width: 100%;
}
